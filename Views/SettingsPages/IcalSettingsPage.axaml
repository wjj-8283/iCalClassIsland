<ci:SettingsPageBase x:Class="iCalClassIsland.Views.SettingsPages.IcalSettingsPage"
      xmlns="https://github.com/avaloniaui"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ci="http://classisland.tech/schemas/xaml/core"
      xmlns:fa="clr-namespace:FluentAvalonia.UI.Controls;assembly=FluentAvalonia"
      x:Name="SettingsPageRoot"
      TextElement.Foreground="{DynamicResource MaterialDesignBody}"
      Background="{DynamicResource MaterialDesignPaper}">
    <ScrollViewer>
        <StackPanel Classes="settings-container animated-intro" Spacing="12">

            <ci:IconText Glyph="&#xE7C5;" Text="数据源" Margin="0 0 0 4"/>
            <fa:SettingsExpander IconSource="{ci:FluentIconSource &#xEA2F;}"
                                 Header="iCal 文件列表"
                                 Description="添加一个或多个 .ics 文件，日程将自动合并并按时间排序。">
                <fa:SettingsExpander.Footer>
                    <StackPanel Spacing="8">
                        <Grid ColumnDefinitions="*,Auto">
                            <ListBox Grid.Column="0" x:Name="FileListBox" MinHeight="60"/>
                            <StackPanel Grid.Column="1" Margin="8 0 0 0" Spacing="4">
                                <Button Content="添加" Click="OnAddFile" Width="60"/>
                                <Button Content="添加 URL" Click="OnAddUrl" Width="60"/>
                                <Button Content="移除" Click="OnRemoveFile" Width="60"/>
                            </StackPanel>
                        </Grid>
                        <!-- Web URL 输入区域 -->
                        <Grid x:Name="UrlInputPanel" ColumnDefinitions="*,Auto" IsVisible="False">
                            <TextBox Grid.Column="0" x:Name="UrlTextBox" Margin="0 0 8 0"
                                     Watermark="输入 iCal 文件的 URL（例如 GitHub Raw）"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                                <Button Content="确定" Click="OnConfirmUrl" Width="50"/>
                                <Button Content="取消" Click="OnCancelUrl" Width="50"/>
                            </StackPanel>
                        </Grid>
                        <TextBlock x:Name="StatusText" TextWrapping="Wrap"
                                   Foreground="{DynamicResource MaterialDesignBodySecondaryBrush}"
                                   FontSize="12"/>
                    </StackPanel>
                </fa:SettingsExpander.Footer>
            </fa:SettingsExpander>

            <ci:IconText Glyph="&#xE1A0;" Text="刷新" Margin="0 8 0 4"/>
            <fa:SettingsExpander IconSource="{ci:FluentIconSource &#xE809;}"
                                 Header="自动刷新间隔"
                                 Description="设置重新读取 iCal 文件的时间间隔。">
                <fa:SettingsExpander.Footer>
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <NumericUpDown x:Name="NumRefreshInterval" Minimum="1" Maximum="1440" Width="100"/>
                        <TextBlock Text="分钟" VerticalAlignment="Center"
                                   Foreground="{DynamicResource MaterialDesignBodySecondaryBrush}"/>
                        <Button Content="立即刷新" Click="OnRefreshClick"/>
                    </StackPanel>
                </fa:SettingsExpander.Footer>
            </fa:SettingsExpander>

            <ci:IconText Glyph="&#xE946;" Text="关于" Margin="0 8 0 4"/>
            <Image x:Name="AboutIcon" Width="72" Height="72" Margin="0 0 0 8"/>
            <fa:SettingsExpander Header="iCal 日程插件"
                                 IsExpanded="True">
                <fa:SettingsExpanderItem>
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0" Text="版本号"/>
                        <TextBlock Grid.Column="1" Text="{Binding VersionText}"/>
                    </Grid>
                </fa:SettingsExpanderItem>
                <fa:SettingsExpanderItem>
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0" Text="commit hash"/>
                        <TextBlock Grid.Column="1" Text="{Binding HashText}"/>
                    </Grid>
                </fa:SettingsExpanderItem>
                <fa:SettingsExpanderItem>
                    <fa:SettingsExpanderItem.Footer>
                        <WrapPanel>
                            <WrapPanel.Styles>
                                <Style Selector="HyperlinkButton">
                                    <Setter Property="Padding" Value="4"/>
                                    <Setter Property="Margin" Value="0 0 8 0"/>
                                </Style>
                            </WrapPanel.Styles>
                            <HyperlinkButton Click="OnOpenGitHub">GitHub 仓库</HyperlinkButton>
                            <HyperlinkButton Click="OnOpenIssue">提交一个 Issue</HyperlinkButton>
                            <HyperlinkButton Click="OnOpenLicense">开放源代码许可</HyperlinkButton>
                        </WrapPanel>
                    </fa:SettingsExpanderItem.Footer>
                </fa:SettingsExpanderItem>
                <fa:SettingsExpanderItem IsVisible="{Binding IsDirty}">
                    <TextBlock Text="⚠ 当前为开发中版本，更改没有提交"
                               FontSize="12"
                               Foreground="{DynamicResource SystemFillColorCautionBrush}"/>
                </fa:SettingsExpanderItem>
            </fa:SettingsExpander>
        </StackPanel>
    </ScrollViewer>
</ci:SettingsPageBase>
